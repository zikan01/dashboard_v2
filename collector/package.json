{
  "name": "gomawo-collector",
  "version": "1.0.0",
  "private": true,
  "description": "고마워할매 대시보드 로컬 수집기 — 네이버 예약자관리 엑셀 자동 다운로드·업로드",
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "package": "npm run build && pkg . --targets node20-win-x64 --output collector.exe"
  },
  "pkg": {
    "assets": [
      "node_modules/playwright-core/**/*",
      "node_modules/officecrypto-tool/**/*"
    ]
  },
  "dependencies": {
    "officecrypto-tool": "^0.0.19",
    "playwright-core": "^1.45.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@yao-pkg/pkg": "^6.3.0",
    "typescript": "^5.4.0"
  }
}
