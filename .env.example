# Supabase (서울 리전 프로젝트) — TRD 핸드오프 §5
# 실제 값은 .env.local 에 직접 입력하세요 (.env.local 은 git에 커밋되지 않음)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=        # 브라우저용(권한 제한)
SUPABASE_SERVICE_ROLE_KEY=            # ⚠️ 서버 전용, 절대 클라이언트 노출 금지

# DB (Prisma — 도입 시)
DATABASE_URL=                         # Supabase Postgres 연결 문자열(pooled)
DIRECT_URL=                           # 마이그레이션용 direct 연결

# 모니터링 (3단계)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# 텍스트 파싱 AI (TBD — 도입 시 활성화, 서버 전용)
# LLM_API_KEY=
# LLM_MODEL=

# ---- 문자 발송 시스템 (TRD v3.1 §22) ----
CRON_SECRET=
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER_NUMBER=
SOLAPI_WEBHOOK_SECRET=
# dry_run(외부 발송 없음) | allowlist(테스트 번호만) | live(운영)
NOTIFICATION_SEND_MODE=dry_run
NOTIFICATION_TEST_PHONE_ALLOWLIST=
